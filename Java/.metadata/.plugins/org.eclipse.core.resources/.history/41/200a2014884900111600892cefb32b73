package tp3;
import java.util.*;
public class RecorridosAG {

	public List numerosImparesMayoresQuePreOrden (GeneralTree a, int n){
		List resultado = new LinkedList();
		buscarImparesMayoresQuePreOrden(a, n, resultado);
		return resultado;
	}
	
	public void imprimirPreOrden(GeneralTree<Integer> a) {
		if ((a == null)&&(a.isEmpty())) {
		return;
		}
	
		System.out.println(a.getData());
		
		for (GeneralTree hijo: a.getChildren()){
			imprimirPreOrden(hijo);
		}
	}
	
	private void buscarImparesMayoresQuePreOrden(GeneralTree<Integer> a, int n, List r) {
		if ((a == null)&&(a.isEmpty())) {
		return;
		}
	
		if ((a.getData() > n) && (a.getData() % 2 != 0)) {
			r.add(a.getData());
		}
		
		for (GeneralTree hijo: a.getChildren()){
			buscarImparesMayoresQuePreOrden(hijo, n, r);
		}
	}
	
	public List numerosImparesMayoresQueInOrden (GeneralTree a, int n){
		List resultado = new LinkedList();
		buscarImparesMayoresQueInOrden(a, n, resultado);
		return resultado;
	}
	
	private void buscarImparesMayoresQueInOrden(GeneralTree<Integer> a, int n, List r) {
		if ((a == null)&&(a.isEmpty())) {
			return;
		}
		if (!a.isLeaf()) {
			GeneralTree primerHijo = a.getChildren().get(0);
			buscarImparesMayoresQueInOrden(primerHijo, n, r);
		}
	
		if ((a.getData() > n) && (a.getData() % 2 != 0)) {
			r.add(a.getData());
		}
	
		List<GeneralTree<Integer>> hijosRestantes = a.getChildren();
		for (int i = 1; i < a.getChildren().size(); i++){
			buscarImparesMayoresQueInOrden(hijosRestantes.get(i), n, r);
		}
	}
	
	public List numerosImparesMayoresQuePostOrden (GeneralTree a, int n){
		List resultado = new LinkedList();
		buscarImparesMayoresQuePostOrden(a, n, resultado);
		return resultado;
	}
	
	private void buscarImparesMayoresQuePostOrden(GeneralTree<Integer> a, int n, List r) {
		if ((a == null)&&(a.isEmpty())) {
			return;
		}
		if (!a.isLeaf()) {
			for (GeneralTree hijo: a.getChildren()){
					buscarImparesMayoresQuePostOrden(hijo, n, r);
			}
		}
		if ((a.getData() > n) && (a.getData() % 2 != 0)) {
			r.add(a.getData());
			return;
		}
	}
	
	public List numerosImparesMayoresQuePorNiveles (GeneralTree<Integer> a, int n){
		List<Integer> resultado = new LinkedList();
		Stack<GeneralTree<Integer>> cola = new Stack();
		cola.add(a);
		buscarImparesMayoresQuePorNiveles(n, resultado, cola);
		return resultado;
	}
	
	private void buscarImparesMayoresQuePorNiveles(int n, List r, Stack<GeneralTree<Integer>> cola) {
		
		if (!cola.isEmpty()) {
			GeneralTree<Integer> actual = cola.getFirst();
			cola.removeFirst();
			if ((actual.getData() > n) && (actual.getData() % 2 != 0)){
				r.add(actual.getData());
			}
			for (GeneralTree<Integer> hijo: actual.getChildren()) {
				cola.add(hijo);
			}
			buscarImparesMayoresQuePorNiveles(n,r,cola);
		}
		
		
	}
}