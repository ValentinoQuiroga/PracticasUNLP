	public static boolean esDeSeleccion (GeneralTree<Integer> arbol) {
		if (arbol == null) {
			return false;
		}
		
		if (!arbol.isLeaf()) {
			boolean auxiliar = false;
			for(GeneralTree<Integer> hijo: arbol.getChildren()) {
				if (hijo.getData() == arbol.getData()) {
					auxiliar = true;
				}
				if (!esDeSeleccion(hijo)) {
					return false;
				}
			}
			return auxiliar;
		}
		return true;
	}
	
